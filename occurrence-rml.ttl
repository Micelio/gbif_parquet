@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gbif: <https://www.gbif.org/occurrence/> .
@prefix gbifterm: <http://rs.gbif.org/terms/1.0/> .
@prefix gbifds: <https://www.gbif.org/dataset/> .
@prefix gbifsp: <https://www.gbif.org/species/> .
@prefix gbifpub: <https://www.gbif.org/publisher/> .
@prefix dwc: <http://rs.tdwg.org/dwc/terms/> .
@prefix dwciri:<http://rs.tdwg.org/dwc/iri/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix tt: <https://www.example.org/namedTaxonomicClaim/> .
@prefix lc: <https://www.example.org/namedLocation/> .

<#OccurrenceQuery> rr:tableName "occurence" .

### ---------------------------------------------------------
### Map 1: Main Occurrence Data
### ---------------------------------------------------------
<#OccurrenceMap>
    a rr:TriplesMap ;
    rr:logicalTable <#OccurrenceQuery> ;

    rr:subjectMap [
        rr:template "https://www.gbif.org/occurrence/{gbifid}" ;
        rr:class dwc:Occurrence ;
    ] ;

    rr:predicateObjectMap [
        rr:predicate gbifterm:gbifID ;
        rr:objectMap [ rr:column "gbifid" ] ;
    ] ;

    rr:predicateObjectMap [
        rr:predicate dwc:occurrenceStatus ;
        rr:objectMap [ rr:column "occurrencestatus" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:individualCount ;
        rr:objectMap [ rr:column "individualcount" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:publishingOrgKey ;
        rr:objectMap [ rr:template "https://www.gbif.org/publisher/{publishingorgkey}" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:decimalLatitude ;
        rr:objectMap [ rr:column "decimallatitude" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:decimalLongitude ;
        rr:objectMap [ rr:column "decimallongitude" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:coordinateUncertaintyInMeters ;
        rr:objectMap [ rr:column "coordinateuncertaintyinmeters" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:coordinatePrecision ;
        rr:objectMap [ rr:column "coordinateprecision" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:elevation ;
        rr:objectMap [ rr:column "elevation" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:elevationAccuracy ;
        rr:objectMap [ rr:column "elevationaccuracy" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:depth ;
        rr:objectMap [ rr:column "depth" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:depthAccuracy ;
        rr:objectMap [ rr:column "depthaccuracy" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:eventDate ;
        rr:objectMap [ rr:column "eventdate" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:day ;
        rr:objectMap [ rr:column "day" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:month ;
        rr:objectMap [ rr:column "month" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:year ;
        rr:objectMap [ rr:column "year" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:basisOfRecord ;
        rr:objectMap [ rr:column "basisofrecord" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:institutionCode ;
        rr:objectMap [ rr:column "institutioncode" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:collectionCode ;
        rr:objectMap [ rr:column "collectioncode" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:catalogNumber ;
        rr:objectMap [ rr:column "catalognumber" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:recordNumber ;
        rr:objectMap [ rr:column "recordnumber" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:identifiedBy ;
        rr:objectMap [ rr:column "identifiedby" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:dateIdentified ;
        rr:objectMap [ rr:column "dateidentified" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:license ;
        rr:objectMap [ rr:column "license" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:rightsHolder ;
        rr:objectMap [ rr:column "rightsholder" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:recordedBy ;
        rr:objectMap [ rr:column "recordedby" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:typeStatus ;
        rr:objectMap [ rr:column "typestatus" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:establishmentMeans ;
        rr:objectMap [ rr:column "establishmentmeans" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:lastInterpreted ;
        rr:objectMap [ rr:column "lastinterpreted" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:mediaType ;
        rr:objectMap [ rr:column "mediatype" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:issue ;
        rr:objectMap [ rr:column "issue" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate wdt:P625 ;
        rr:objectMap [
            rr:column "point" ;
            rr:datatype geo:wktLiteral
        ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwciri:toTaxon ;
        rr:objectMap [ rr:template "https://www.example.org/namedTaxonomicClaim/{taxon_string}" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwciri:inDescribedPlace ;
        rr:objectMap [ rr:template "https://www.example.org/namedLocation/{geography_string}" ] ;
    ] .

### ---------------------------------------------------------
### Map 2: Taxonomic Claim Breakdown
### ---------------------------------------------------------
<#TaxonClaimMap>
    a rr:TriplesMap ;
    rr:logicalTable <#OccurrenceQuery> ;

    rr:subjectMap [
        rr:template "https://www.example.org/namedTaxonomicClaim/{taxon_string}" ;
    ] ;

    rr:predicateObjectMap [
        rr:predicate dwc:kingdom ;
        rr:objectMap [ rr:column "kingdom" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:phylum ;
        rr:objectMap [ rr:column "phylum" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:class ;
        rr:objectMap [ rr:column "class" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:order ;
        rr:objectMap [ rr:column "order" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:family ;
        rr:objectMap [ rr:column "family" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:genus ;
        rr:objectMap [ rr:column "genus" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:species ;
        rr:objectMap [ rr:column "species" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:infraspecificEpithet ;
        rr:objectMap [ rr:column "infraspecificepithet" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:taxonRank ;
        rr:objectMap [ rr:column "taxonrank" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:scientificName ;
        rr:objectMap [ rr:column "scientificname" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:verbatimScientificName ;
        rr:objectMap [ rr:column "verbatimscientificname" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:taxonKey ;
        rr:objectMap [ rr:template "https://www.gbif.org/species/{taxonkey}" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:speciesKey ;
        rr:objectMap [ rr:template "https://www.gbif.org/species/{specieskey}" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:verbatimScientificNameAuthorship ;
        rr:objectMap [ rr:column "verbatimscientificnameauthorship" ] ;
    ] .
### ---------------------------------------------------------
### Map 2: Named Location
### ---------------------------------------------------------
<#NamedLocation>
    a rr:TriplesMap ;
    rr:logicalTable <#OccurrenceQuery> ;

    rr:subjectMap [
        rr:template "https://www.example.org/namedLocation/{geography_string}" ;
    ] ;

    rr:predicateObjectMap [
        rr:predicate dwc:countryCode ;
        rr:objectMap [ rr:column "countrycode" ] ;
    ] ;

   rr:predicateObjectMap [
        rr:predicate dwc:locality ;
        rr:objectMap [ rr:column "locality" ] ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate dwc:stateProvince ;
        rr:objectMap [ rr:column "stateprovince" ] ;
    ] .
